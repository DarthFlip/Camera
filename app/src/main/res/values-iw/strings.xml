    <string name="camera_permission_dialog_title">נדרשת הרשאת מצלמה</string>
    <string name="camera_permission_dialog_message">
        האפליקציה זקוקה להרשאת גישה למצלמה כדי לפעול. אנא אשור את ההרשאה הנדרשת דרך ההגדרות כדי להשתמש באפליקציה זו.
    </string>

    <string name="audio_permission_dialog_title">נדרשת הרשאת שמע</string>
    <string name="audio_permission_dialog_message">האפליקציה זקוקה להרשאת גישה למיקרופון כדי להקליט וידאו הכולל שמע. אנא אשור את ההרשאה הנדרשת דרך ההגדרות כדי להמשיך. אם אינך זקוק לשמע בוידאו, ניתן לבטל אפשרות זו (ולהפעילה מחדש מאוחר יותר בהגדרות).</string>

    <string name="location_permission_dialog_title">נדרשת הרשאת מיקום</string>
    <string name="location_permission_dialog_message">
        האפליקציה זקוקה להרשאת מיקום לצורך תיוג גיאוגרפי (Geo-tagging). אנא אשור את ההרשאה הנדרשת דרך ההגדרות כדי להשתמש באפליקציה זו.
    </string>

